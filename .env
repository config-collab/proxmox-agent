# Proxmox management agent — environment configuration
# Copy this file to banapi alongside the SSH keys, then adjust SSH_KEYS_DIR.

# ── Proxmox host ───────────────────────────────────────────────────────────────
PROXMOX_HOST=192.168.0.91
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
# Leave PROXMOX_PASS empty — key auth is used for SSH; API uses ticket auth
PROXMOX_PASS=

# ── SSH to Proxmox host ────────────────────────────────────────────────────────
SSH_HOST=192.168.0.91
SSH_USER=root
SSH_KEY=proxmox_id_ed25519

# ── Path to the SSH keys directory ────────────────────────────────────────────
# Windows dev machine:
SSH_KEYS_DIR=D:\SSH Keys
# On banapi, override to wherever you copy the keys, e.g.:
# SSH_KEYS_DIR=/home/pi/.proxmox-agent/keys

# ── Guest SSH keys (keyed by guest name) ──────────────────────────────────────
GUEST_KEY_turnkey-fileserver=turnkey_id_ed25519
GUEST_KEY_pihole=pihole_id_ed25519
GUEST_KEY_heimdall-dashboard=heimdall_id_ed25519
GUEST_KEY_pihole-backup=pihole-backup_id_ed25519
GUEST_KEY_plex=plex_id_ed25519
GUEST_KEY_proxmox-backup-server=pbs_id_ed25519
GUEST_KEY_debian=debian_id_ed25519
GUEST_KEY_homecloud=homecloud_id_ed25519
GUEST_KEY_seeding=seeding_id_ed25519

# ── Guest IPs (for direct SSH into guests) ────────────────────────────────────
GUEST_IP_turnkey-fileserver=192.168.0.93
GUEST_IP_pihole=192.168.0.94
GUEST_IP_heimdall-dashboard=192.168.0.96
GUEST_IP_pihole-backup=192.168.0.99
GUEST_IP_plex=192.168.0.97
GUEST_IP_proxmox-backup-server=192.168.0.244
GUEST_IP_debian=192.168.0.81
GUEST_IP_homecloud=192.168.0.92
GUEST_IP_seeding=192.168.0.228

# ── Home Assistant ─────────────────────────────────────────────────────────────
HA_URL=http://192.168.0.85:8123

# ── Backup / alert thresholds ──────────────────────────────────────────────────
BACKUP_STORAGE=local-pbs
BACKUP_MAX_AGE_H=24
STORAGE_WARN_PCT=80
