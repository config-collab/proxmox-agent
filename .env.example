# Proxmox Management Agent — Configuration Template
# Copy this file to `.env` and fill in your actual values
# DO NOT commit .env to git — it will be ignored by .gitignore

# ── Proxmox Host Connection ─────────────────────────────────────────────────────
PROXMOX_HOST=192.168.x.x          # IP of your Proxmox node
PROXMOX_PORT=8006                 # Default: 8006
PROXMOX_USER=root@pam             # User with API access
PROXMOX_API_TOKEN=                # API token (preferred over password)
# OR use password auth (less secure):
# PROXMOX_PASS=your-password

# ── SSH Access to Proxmox Host ──────────────────────────────────────────────────
SSH_HOST=192.168.x.x              # Same as PROXMOX_HOST
SSH_USER=root                      # SSH username
SSH_KEY=proxmox_id_ed25519        # Key filename (in SSH_KEYS_DIR)
SSH_KEYS_DIR=~/.proxmox-agent/keys # Directory where SSH keys are stored

# ── Guest SSH Keys (per-guest configuration) ────────────────────────────────────
# Format: GUEST_KEY_<guest-name>=<key-filename>
# GUEST_KEY_pihole=pihole_id_ed25519
# GUEST_KEY_homeassistant=ha_id_ed25519

# ── Guest IPs (for direct SSH into guests) ──────────────────────────────────────
# Format: GUEST_IP_<guest-name>=<ip-address>
# GUEST_IP_pihole=192.168.1.100
# GUEST_IP_homeassistant=192.168.1.101

# ── Backup Configuration ────────────────────────────────────────────────────────
BACKUP_STORAGE=local-pbs          # PBS storage target name
PBS_HOST=192.168.x.x              # IP of Proxmox Backup Server (if different from PROXMOX_HOST)
BACKUP_MAX_AGE_H=24               # Alert if backup older than this

# ── LLM Provider Configuration ──────────────────────────────────────────────────
LLM_PROVIDER=claude               # Options: claude, openai, ollama
ANTHROPIC_API_KEY=sk-ant-...      # Claude API key (get from https://console.anthropic.com)
# OR for OpenAI:
# OPENAI_API_KEY=sk-...

# ── Security Settings ──────────────────────────────────────────────────────────
AGENT_AUTONOMY=1                  # 0=observe, 1=suggest, 2=maintain, 3=full
PVE_PROTECTION_MODE=strict        # strict, warn, off
PRE_CHANGE_BACKUP=snapshot        # none, snapshot, pbs
PROTECTED_TARGETS=pve localhost   # Hosts that can't be touched (strict mode)

# ── Audit & Logging ────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=~/.proxmox-agent/audit.jsonl  # Where to write audit logs
AUDIT_FLUSH_INTERVAL=50           # Flush logs every N operations

# ── Alerts (Optional) ──────────────────────────────────────────────────────────
NTFY_URL=https://ntfy.sh/your-topic    # Push notifications (optional)
SLACK_WEBHOOK=                        # Or Slack webhooks (optional)

# ── Internal (auto-generated, don't edit) ──────────────────────────────────────
# PROXMOX_TOKEN_EXPIRY=
# LAST_INVENTORY_UPDATE=
# AGENT_VERSION=
